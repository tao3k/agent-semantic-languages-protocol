{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-org-contract-trace.v1.schema.json",
  "title": "Semantic Org Contract Trace",
  "description": "Parser-owned CONTRACT_ORG evaluation trace emitted by orgize and consumed by downstream agent harnesses.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "files"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileTrace"
      }
    }
  },
  "$defs": {
    "fileTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "evaluations"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "evaluations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evaluation"
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "contractId", "scope", "assertions"],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "contractId": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "assertions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assertion"
          }
        }
      }
    },
    "scope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "range"],
          "properties": {
            "kind": {
              "const": "document"
            },
            "range": {
              "$ref": "#/$defs/range"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "title", "outlinePath", "range"],
          "properties": {
            "kind": {
              "const": "section"
            },
            "title": {
              "type": "string"
            },
            "outlinePath": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "range": {
              "$ref": "#/$defs/range"
            }
          }
        }
      ]
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertionId",
        "severity",
        "expectation",
        "actualCount",
        "status",
        "matchedIds",
        "bindings"
      ],
      "properties": {
        "assertionId": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["error", "warning"]
        },
        "expectation": {
          "$ref": "#/$defs/expectation"
        },
        "actualCount": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "enum": ["passed", "failed"]
        },
        "matchedIds": {
          "$ref": "#/$defs/elementIds"
        },
        "bindings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/elementIds"
          }
        },
        "messageTemplate": {
          "type": "string"
        },
        "fixTemplate": {
          "type": "string"
        }
      }
    },
    "expectation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "exists"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "notExists"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "operator", "count"],
          "properties": {
            "kind": {
              "const": "count"
            },
            "operator": {
              "enum": ["==", "!=", "<", "<=", ">", ">="]
            },
            "count": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "elementIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
