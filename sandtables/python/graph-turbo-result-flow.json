  "evidence": {
    "source": "handwritten",
    "intent": "Validate that asp-graph-turbo consumes a schema-owned algorithm request and emits a schema-owned typed frontier ranking response instead of relying on prompt text as the source of truth.",
    "intentKind": "implementation-principle",
    "editBoundary": "none",
    "metrics": {
      "recordedCommandCount": 4,
            "repeatedSearches": 0,
            "jsonSearches": 3,
            "compactSearches": 0,
      "tokenDelta": "same"
    },
    "findings": [
            {
                "kind": "graph-turbo-packet",
                "severity": "info",
                "message": "Graph turbo ranking evidence is validated as semantic-graph-turbo-summary before any compact renderer consumes it."
            },
            {
                "kind": "graph-turbo-benchmark",
                "severity": "info",
                "message": "Graph turbo benchmark evidence is validated as semantic-graph-turbo-benchmark with path backend and candidate width metrics."
            },
      {
        "kind": "graph-turbo-sandtable-summary",
        "severity": "info",
        "message": "Benchmark metrics and frontier receipt facts are joined into a schema-owned sandtable summary row."
      },
      {
        "kind": "graph-turbo-ablation-report",
        "severity": "info",
        "message": "Ablation calibration evidence validates provider facts, receipt, read-memory, and edge quality signals through a schema-owned quality gate."
      }
    ]
  },
  "steps": [
        {
            "id": "graph-turbo-json-packet",
      "kind": "schema-contract",
      "coverage": [
        "json-schema",
        "search-flow"
      ],
      "command": [
        "uv",
        "run",
        "--frozen",
        "--project",
        "packages/python",
        "python",
        "-m",
        "tools",
        "graph",
        "turbo",
        "sandtables/fixtures/asp/graph-turbo-owner-query.json",
        "--format",
	        "summary-json"
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-graph-turbo-summary.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-graph-turbo-summary",
          "packetKind": "graph-turbo-summary",
          "summaryKind": "frontier-projection",
          "sourceSchemaId": "agent.semantic-protocols.semantic-graph-turbo-result",
          "sourcePacketKind": "graph-turbo-result",
          "profile": "owner-query",
          "algorithm": "typed-ppr-diverse",
          "seedIds.0": "q:parser",
          "seedIds.1": "owner:cli",
          "profiles.0": "owner-query",
          "omit.0": "code",
                    "avoid.0": "raw-read",
                    "profileCompatibility.0.profile": "owner-query",
                    "profileMatrices.0.profile": "owner-query",
                    "sourceSinkFrontier.sourceIds.0": "q:parser",
          "sourceSinkFrontier.sourceIds.1": "owner:cli",
          "graphCache.backend": "scipy-csr",
          "algorithmTrace.2.step": "profile-policy",
          "algorithmTrace.3.step": "typed-ppr"
        },
        "stdoutJsonArrayContains": {
          "rankedNodes": {
            "id": "item:graph-turbo",
            "kind": "item",
            "action": "code",
            "owner": "packages/python/tools/src/tools/cli.py",
            "symbol": "graph_turbo"
          },
          "typedPaths": {
            "id": "P1",
            "pathKind": "constrained-shortest"
          },
          "edges": {
            "source": "owner:cli",
            "target": "test:cli",
            "relation": "covers",
            "weight": 1.4
          }
        },
        "stdoutNotContains": [
          "[graph-turbo]",
          "legend:"
        ],
        "stdoutContains": [
          "\"algorithmMetrics\"",
          "\"pathCount\"",
          "\"packetFingerprint\"",
          "\"profileMatrices\"",
          "\"relationChannels\"",
          "\"full-score-vector\""
        ],
        "maxStdoutLinesWarn": 1,
	                "maxStdoutBytesWarn": 12000,
                "maxElapsedMsWarn": 10000
            }
        },
        {
