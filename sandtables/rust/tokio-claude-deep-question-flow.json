{
  "id": "rust.tokio-claude-deep-question-flow",
  "title": "Tokio 0.6.0 live Claude deep question command audit flow",
  "language": "rust",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "tokio",
    "claude",
    "deep-question",
    "live"
  ],
  "skipUnlessEnv": [
    "ASP_LIVE_CLAUDE_CLI",
    "ANTHROPIC_AUTH_TOKEN",
    "SANDTABLE_RUST_TOKIO_060_ROOT"
  ],
  "execution": {
    "mode": "parallel",
    "maxConcurrentSteps": 1
  },
  "evidence": {
    "source": "real-trigger",
    "targetLibrary": {
      "language": "rust",
      "name": "Tokio",
      "package": "tokio",
      "repository": "tokio-rs/tokio",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "api-usage",
        "intent": "Ask Claude to explain the API-facing meaning of Vec<scalar> collection fields from parser-owned evidence",
        "stepIds": [
          "claude-tokio-vec-scalar-meaning"
        ],
        "queryTerms": [
          "Vec",
          "scalar",
          "collection",
          "fields"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "tokio-vec-scalar-collection-fields",
        "question": "In Tokio 0.6.0, what do Vec<scalar> collection fields mean, and why are they not modeled as ordinary scalar fields?",
        "stepIds": [
          "claude-tokio-vec-scalar-meaning"
        ],
        "queryTerms": [
          "Vec",
          "scalar",
          "collection",
          "fields"
        ],
        "audit": {
          "maxAspCommands": 8,
          "maxSearchCommands": 4,
          "maxQueryCommands": 4,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true,
          "requiresComplexPipeFlow": true,
          "requiresTokenCost": true
        },
        "expectedAspFlow": {
          "canonicalCommands": [
            "asp rust search prime --view seeds .",
            "asp rust search pipe 'Vec scalar collection fields' --view seeds .",
            "asp rust search reasoning owner-query --owner <owner-path> --query 'Vec scalar collection fields' --view seeds .",
            "asp rust query --selector <field-or-owner-selector> --code ."
          ],
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "search-reasoning",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands"
          ],
          "notes": [
            "Prime exactly once to build the project graph context, then start search pipe and follow the emitted pipeCommands.",
            "The owner-query command is available when the first pipe frontier does not already expose an exact selector."
          ]
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_TOKIO_060_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/tokio-0.6.0"
    ]
  },
  "budgets": {
    "maxCommands": 1,
    "maxTotalElapsedMsWarn": 120000,
    "maxTotalStdoutBytesWarn": 200000
  },
  "steps": [
    {
      "id": "claude-tokio-vec-scalar-meaning",
      "kind": "agent-sdk",
      "agentSdk": {
        "client": "claude",
        "prompt": "In tokio 0.6.0, what do Vec<scalar> collection fields mean, and why are they not modeled as ordinary scalar fields? Use this repository's SKILL.md and ASP search/query workflow. Start with asp rust search prime --view seeds . once, then asp rust search pipe 'Vec scalar collection fields' --view seeds ., follow its pipeCommands through reasoning, then query selectors before any exact code read. List the asp commands you actually ran at the end.",
        "outputFormat": "stream-json",
        "includeHookEvents": true,
        "verbose": true,
        "allowedTools": [
          "Bash"
        ],
        "requireAspBashCommands": true,
        "useRepoClaudeSettings": true,
        "maxTurns": 9,
        "env": {
          "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_AUTH_TOKEN}"
        },
        "requiredEnv": [
          "ANTHROPIC_AUTH_TOKEN"
        ]
      },
      "timeoutSeconds": 120,
      "expect": {
        "allowNonZeroExit": true,
        "pipeFlow": {
          "maxAspCommands": 8,
          "maxSearchCommands": 4,
          "maxQueryCommands": 4,
          "maxRepeatedCommands": 0,
          "maxSearchPipeCommands": 1,
          "maxSearchPrimeCommands": 1,
          "minQuerySelectorCommands": 1,
          "requireComplexPipeFlow": true,
          "requireTokenCost": true,
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "search-reasoning",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands"
          ]
        },
        "stdoutContains": [
          "Vec",
          "scalar"
        ],
        "maxStdoutBytesWarn": 200000,
        "maxElapsedMsWarn": 120000
      }
    }
  ]
}
